{
  "realm": "airmcp",
  "enabled": true,
  "accessTokenLifespan": 3600,
  "sslRequired": "none",
  "registrationAllowed": false,
  "loginWithEmailAllowed": true,
  "duplicateEmailsAllowed": false,
  "resetPasswordAllowed": false,
  "editUsernameAllowed": false,
  "bruteForceProtected": true,
  "users": [
    {
      "username": "dev",
      "enabled": true,
      "emailVerified": true,
      "firstName": "AirMCP",
      "lastName": "Dev",
      "email": "dev@airmcp.local",
      "credentials": [
        {
          "type": "password",
          "value": "dev",
          "temporary": false
        }
      ],
      "realmRoles": ["default-roles-airmcp"],
      "clientRoles": {
        "airmcp-dev": ["mcp:read", "mcp:write", "mcp:destructive", "mcp:admin"]
      }
    }
  ],
  "clientScopes": [
    {
      "name": "mcp:read",
      "protocol": "openid-connect",
      "attributes": {
        "include.in.token.scope": "true",
        "display.on.consent.screen": "true"
      }
    },
    {
      "name": "mcp:write",
      "protocol": "openid-connect",
      "attributes": {
        "include.in.token.scope": "true",
        "display.on.consent.screen": "true"
      }
    },
    {
      "name": "mcp:destructive",
      "protocol": "openid-connect",
      "attributes": {
        "include.in.token.scope": "true",
        "display.on.consent.screen": "true"
      }
    },
    {
      "name": "mcp:admin",
      "protocol": "openid-connect",
      "attributes": {
        "include.in.token.scope": "true",
        "display.on.consent.screen": "true"
      }
    }
  ],
  "clients": [
    {
      "clientId": "airmcp-dev",
      "name": "AirMCP Dev Client",
      "enabled": true,
      "publicClient": true,
      "directAccessGrantsEnabled": true,
      "standardFlowEnabled": true,
      "serviceAccountsEnabled": false,
      "redirectUris": [
        "http://localhost:3000/*",
        "http://127.0.0.1:3000/*"
      ],
      "webOrigins": ["http://localhost:3000", "http://127.0.0.1:3000"],
      "attributes": {
        "pkce.code.challenge.method": "S256",
        "access.token.lifespan": "3600"
      },
      "defaultClientScopes": ["mcp:read"],
      "optionalClientScopes": ["mcp:write", "mcp:destructive", "mcp:admin"]
    }
  ]
}
