{
  "name": "airmcp",
  "version": "2.6.3",
  "description": "MCP server for the entire Apple ecosystem — Notes, Reminders, Calendar, Contacts, Mail, Messages, Music, Finder, Safari, System, Photos, Shortcuts, Apple Intelligence, TV, Screen Capture, Maps, and Podcasts. Connect any AI to your Mac.",
  "keywords": [
    "mcp",
    "model-context-protocol",
    "apple",
    "notes",
    "apple-notes",
    "reminders",
    "apple-reminders",
    "calendar",
    "apple-calendar",
    "apple-intelligence",
    "contacts",
    "apple-contacts",
    "mail",
    "apple-mail",
    "messages",
    "imessage",
    "music",
    "apple-music",
    "finder",
    "safari",
    "apple-safari",
    "photos",
    "apple-photos",
    "shortcuts",
    "siri-shortcuts",
    "clipboard",
    "dark-mode",
    "claude",
    "cursor",
    "windsurf",
    "cline",
    "llm",
    "ai",
    "applescript",
    "macos"
  ],
  "homepage": "https://github.com/heznpc/AirMCP",
  "bugs": {
    "url": "https://github.com/heznpc/AirMCP/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/heznpc/AirMCP.git"
  },
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "author": "heznpc",
  "mcpName": "io.github.heznpc/airmcp",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "airmcp": "dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "node scripts/build.mjs",
    "swift-build": "cd swift && swift build -c release",
    "app-build": "cd app && swift build -c release",
    "clean": "rm -rf dist",
    "dev": "tsx src/index.ts",
    "lint": "eslint src/",
    "format": "prettier --write src/",
    "format:check": "prettier --check src/",
    "prepublishOnly": "npm run clean && npm run build",
    "pretest": "npm run build",
    "start": "node dist/index.js",
    "test": "node --experimental-vm-modules node_modules/.bin/jest",
    "qa": "node scripts/qa-test.mjs",
    "qa:crud": "node scripts/qa-crud-test.mjs",
    "qa:e2e": "node scripts/qa-e2e-test.mjs",
    "qa:remaining": "node scripts/qa-remaining-test.mjs",
    "qa:seq": "node scripts/qa-sequential.mjs",
    "debug": "node scripts/debug-pipeline.mjs",
    "debug:all": "node scripts/debug-pipeline.mjs --all",
    "debug:list": "node scripts/debug-pipeline.mjs --list",
    "dev:test": "node scripts/dev-test.mjs",
    "dev:test:changed": "node scripts/dev-test.mjs --changed",
    "dev:test:watch": "node scripts/dev-test.mjs --watch",
    "typecheck": "tsc --noEmit",
    "version:patch": "npm version patch --no-git-tag-version && node scripts/sync-version.mjs",
    "version:minor": "npm version minor --no-git-tag-version && node scripts/sync-version.mjs",
    "version:major": "npm version major --no-git-tag-version && node scripts/sync-version.mjs",
    "version:check": "node scripts/sync-version.mjs --check",
    "stats": "node scripts/count-stats.mjs",
    "stats:check": "node scripts/count-stats.mjs --check",
    "i18n:check": "node scripts/check-i18n.mjs",
    "llms": "node scripts/gen-llms-txt.mjs",
    "prepare": "husky"
  },
  "dependencies": {
    "@modelcontextprotocol/ext-apps": "1.3.1",
    "@modelcontextprotocol/sdk": "1.29.0",
    "express": "^5.2.1",
    "yaml": "^2.8.2",
    "zod": "~3.25.76"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.4.4",
    "@commitlint/config-conventional": "^20.4.4",
    "@eslint/js": "^10.0.1",
    "esbuild": "^0.25.0",
    "@jest/globals": "^30.3.0",
    "@types/express": "^5.0.6",
    "@types/node": "^25.5.0",
    "eslint": "^10.0.3",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.4.0",
    "husky": "^9.1.7",
    "jest": "^30.3.0",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.1",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.20.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "os": [
    "darwin"
  ],
  "lint-staged": {
    "src/**/*.ts": [
      "prettier --write",
      "eslint --fix"
    ]
  }
}
