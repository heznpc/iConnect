{
  "name": "airmcp",
  "version": "1.6.0",
  "description": "MCP server for the entire Apple ecosystem — Notes, Reminders, Calendar, Contacts, Mail, Messages, Music, Finder, Safari, System, Photos, Shortcuts, Apple Intelligence, TV, Screen Capture, Maps, and Podcasts. Connect any AI to your Mac.",
  "keywords": [
    "mcp",
    "model-context-protocol",
    "apple",
    "notes",
    "apple-notes",
    "reminders",
    "apple-reminders",
    "calendar",
    "apple-calendar",
    "apple-intelligence",
    "contacts",
    "apple-contacts",
    "mail",
    "apple-mail",
    "messages",
    "imessage",
    "music",
    "apple-music",
    "finder",
    "safari",
    "apple-safari",
    "photos",
    "apple-photos",
    "shortcuts",
    "siri-shortcuts",
    "clipboard",
    "dark-mode",
    "claude",
    "cursor",
    "windsurf",
    "cline",
    "llm",
    "ai",
    "applescript",
    "macos"
  ],
  "homepage": "https://github.com/heznpc/AirMCP",
  "bugs": {
    "url": "https://github.com/heznpc/AirMCP/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/heznpc/AirMCP.git"
  },
  "license": "MIT",
  "author": "heznpc",
  "mcpName": "io.github.heznpc/airmcp",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "airmcp": "dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "swift-build": "cd swift && swift build -c release",
    "app-build": "cd app && swift build -c release",
    "clean": "rm -rf dist",
    "dev": "tsx src/index.ts",
    "lint": "eslint src/",
    "prepublishOnly": "npm run clean && npm run build",
    "pretest": "npm run build",
    "start": "node dist/index.js",
    "test": "node --experimental-vm-modules node_modules/.bin/jest",
    "typecheck": "tsc --noEmit",
    "version:patch": "npm version patch --no-git-tag-version && node -e \"let s=require('./server.json');s.version=s.packages[0].version=require('./package.json').version;require('fs').writeFileSync('server.json',JSON.stringify(s,null,2)+'\\n')\"",
    "version:minor": "npm version minor --no-git-tag-version && node -e \"let s=require('./server.json');s.version=s.packages[0].version=require('./package.json').version;require('fs').writeFileSync('server.json',JSON.stringify(s,null,2)+'\\n')\"",
    "version:major": "npm version major --no-git-tag-version && node -e \"let s=require('./server.json');s.version=s.packages[0].version=require('./package.json').version;require('fs').writeFileSync('server.json',JSON.stringify(s,null,2)+'\\n')\""
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "express": "^5.2.1",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@jest/globals": "^29.7.0",
    "@types/express": "^5.0.6",
    "@types/node": "^22.0.0",
    "eslint": "^10.0.3",
    "globals": "^16.0.0",
    "jest": "^30.3.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.20.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "os": [
    "darwin"
  ]
}
